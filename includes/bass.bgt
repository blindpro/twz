bool get_echoparameters(long fxhandle, float &out fWetDryMix, float &out fFeedback, float &out fLeftDelay, float &out fRightDelay, int &out lPanDelay)
{
string result="";
result.resize(50);
int l=-1;
dictionary s=dllib.call("long get_echoparameters(long, char*, char*, char*, char*, int*);", fxhandle, result, result, result, result, l);
s.get(0, l);
bool success=(l>0) ? true : false;
if(!success)
return success;
s.get(2, result);
fWetDryMix=string_to_number(string_replace(result, "\0", "", true));
s.get(3, result);
fFeedback=string_to_number(string_replace(result, "\0", "", true));
s.get(4, result);
fLeftDelay=string_to_number(string_replace(result, "\0", "", true));
s.get(5, result);
fRightDelay=string_to_number(string_replace(result, "\0", "", true));
s.get(6, lPanDelay);
return success;
}

bool get_i3dl2reverbparameters(long fxhandle, int &out lRoom, int &out lRoomHF, float &out flRoomRolloffFactor, float &out flDecayTime, float &out flDecayHFRatio, int &out lReflections, float &out flReflectionsDelay, int &out lReverb, float &out flReverbDelay, float &out flDiffusion, float &out flDensity, float &out flHFReference)
{
string result="";
result.resize(2048);
dictionary s=dllib.call("long get_i3dl2reverbparameters(long, char*);", fxhandle, result);
int l;
s.get(0, l);
bool success=(l>=1) ? true : false;
if(!success)
return success;
s.get(2, result);
result=string_replace(result, "\0", "", true);
string [] act=string_split(result, ":", true);
if(act.length<12)
return false;
lRoom=string_to_number(act[0]);
lRoomHF=string_to_number(act[1]);
flRoomRolloffFactor=string_to_number(act[2]);
flDecayTime=string_to_number(act[3]);
flDecayHFRatio=string_to_number(act[4]);
lReflections=string_to_number(act[5]);
flReflectionsDelay=string_to_number(act[6]);
lReverb=string_to_number(act[7]);
flReverbDelay=string_to_number(act[8]);
flDiffusion=string_to_number(act[9]);
flDensity=string_to_number(act[10]);
flHFReference=string_to_number(act[11]);
return success;
}

string [] list_input_devices()
{
string result="";
result.resize(1024);
dictionary s=dllib.call("void list_input_devices(char*);", result);
s.get(1, result);
result=string_replace(result, "\0", "", true);
string [] devices;
if(result=="")
return devices;
devices=string_split(result, "\r\n", true);
return devices;
}

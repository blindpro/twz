string seconds_to_string(long total_seconds)
{
string final="";
int d=total_seconds/60/60/24;
int h=total_seconds/60/60;
int m=total_seconds/60%60;
int s=total_seconds%60;
if(d==1)
final+=d+" day";
else if(d>1)
final+=d+" days";
if(h==1)
final+h+" hour";
else if(h>1)
final+=h+" hours";
if(m==1)
final+=m+" minute";
else if(m>1)
final+=m+" minutes";
if(s==1)
final+=s+" second";
else if(s>1)
final+=s+" seconds";
return final;
}
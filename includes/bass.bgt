const int BASS_TAG_MUSIC_SAMPLE=0x10300;// + sample #, MOD sample name : ANSI string
const int BASSVERSION=0x204; 	// API version
const string BASSVERSIONTEXT="2.4";
library dllib;
bool init_bass(long device, long freq, long flags)
{
if(!dllib.load("libraries/dllib.dll"))
return false;
dictionary s=dllib.call("long init_bass(long, long, long);", device, freq, flags);
long r;
s.get(0, r);
bool success=(r>=1) ? true : false;
return success;
}
long streamCreate(long freq, long chans, long flags)
{
dictionary s=dllib.call("long streamCreate(long, long, long);", freq, chans, flags);
int l;
s.get(0, l);
return l;
}
long loadfile(string filename, long flags)
{
dictionary s=dllib.call("long loadStream(BOOL, char*, long);", false, filename, flags);
int l;
s.get(0, l);
return l;
}
long loadurl(string url, long flags)
{
dictionary s=dllib.call("long loadUrl(char*, long);", url, flags);
int l;
s.get(0, l);
return l;
}
long loadurl(string url, long flags, string filename)
{
dictionary s=dllib.call("long loadurl(char*, long, char*);", url, flags, filename);
int l;
s.get(0, l);
return l;
}
long StreamCreateFileUser(long system, long flags)
{
dictionary s=dllib.call("long StreamCreateFileUser(long, long);", system, flags);
int l;
s.get(0, l);
return l;
}
bool channelplay(long handle, bool restart=false)
{
dictionary s=dllib.call("long channelPlay(long, BOOL);", handle, restart);
int l;
s.get(0, l);
bool success=(l>=1) ? true : false;
return success;
}
bool setconfig(long option, long value)
{
dictionary s=dllib.call("long setConfig(long, long);", option, value);
int l;
s.get(0, l);
bool success=(l>=1) ? true : false;
return success;
}
double getconfig(long option)
{
dictionary s=dllib.call(" double getConfig(long);", option);
double l;
s.get(0, l);
return l;
}
bool SetConfigPtr(long option, long value)
{
dictionary s=dllib.call("long SetConfigPtr(long, long);", option, value);
int l;
s.get(0, l);
bool success=(l>=1) ? true : false;
return success;
}
bool isactive(long handle)
{
dictionary s=dllib.call("long isActive(long);", handle);
int l;
s.get(0, l);
bool active=(l==BASS_ERROR_FILEOPEN?false:true);
return active;
}
bool isplaying(long handle)
{
dictionary s=dllib.call("long isActive(long);", handle);
int l;
s.get(0, l);
bool playing=(l==BASS_ACTIVE_PLAYING?true:false);
return playing;
}
bool channelpause(long handle)
{
dictionary s=dllib.call("long channelPause(long);", handle);
int l;
s.get(0, l);
bool success=(l>=1) ? true : false;
return success;
}
double getposition(long handle)
{
dictionary s=dllib.call("double getPosition(long);", handle);
double l;
s.get(0, l);
return l;
}
double getlength(long handle)
{
dictionary s=dllib.call("double getLength(long);", handle);
double l;
s.get(0, l);
return l;
}

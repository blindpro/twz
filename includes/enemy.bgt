{
enemies[i].z-=1;
if(enemies[i].type>6) p.play_3d(get_tile_at2(enemies[i].x,enemies[i].y,enemies[i].z)+"step"+random(1,5),me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,tilevolume,tilepitch,tilespeed,false);
}
}
if(enemies[i].z<enemies[i].dz and enemies[i].movetimer.elapsed>=enemies[i].movetime and enemies[i].dead==false)
{
enemies[i].movetimer.restart();
if(string_contains(get_tile_at(enemies[i].x, enemies[i].y, enemies[i].z), "wall", 1)>-1)
{
if(enemies[i].type>6) p.play_3d(get_tile_at(enemies[i].x, enemies[i].y, enemies[i].z), me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,enemies[i].facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
}
else
{
enemies[i].z+=1;
if(enemies[i].type>6) p.play_3d(get_tile_at2(enemies[i].x,enemies[i].y,enemies[i].z)+"step"+random(1,5),me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,tilevolume,tilepitch,tilespeed,false);
}
}
}
}
}
}
void spawn_enemy(int type,int x, int y, int z, string invehicle="")
{
enemy e1(type,x,y,z,invehicle);
enemies.insert_last(e1);
}
void destroy_all_enemies()
{
for (uint i=0; i<enemies.length(); i++)
{
enemies[i].burnloop.close();
enemies[i].item_grabberloop.close();
enemies[i].enemy_grabberloop.close();
enemies[i].voice.close();
}
enemies.resize(0);
}

void stun(int ms)
{
if(this.stunagaintimer.elapsed<=this.stunagaintime)
{
return;
}
else
{
this.stunagaintime=0;
this.stunagaintimer.restart();
}
stunned=true;
stuntime=ms;
stuntimer.restart();
this.stunagaintime=ms;
}
}
void eloop()
{
for (uint i=0; i<enemies.length(); i++)
{
if(enemies[i].burned and enemies[i].dead==false) position_sound_3d(enemies[i].burnloop, me.x, me.y, me.z, enemies[i].x, enemies[i].y, enemies[i].z, facing, 10, 5, 5, 0, 100, 0);
if(enemies[i].itemgrabber and enemies[i].dead==false) position_sound_3d(enemies[i].item_grabberloop, me.x, me.y, me.z, enemies[i].x, enemies[i].y, enemies[i].z, facing, 10, 5, 5, 0, 100, 0);
if(enemies[i].enemygrabber and enemies[i].dead==false) position_sound_3d(enemies[i].enemy_grabberloop, me.x, me.y, me.z, enemies[i].x, enemies[i].y, enemies[i].z, facing, 10, 5, 5, 0, 100, 0);
if(enemies[i].type<7 and enemies[i].dead==false)
{
position_sound_3d(enemies[i].voice, me.x, me.y, me.z, enemies[i].x, enemies[i].y, enemies[i].z, facing, 10, 5, 5, 0, 100, 0);
}
else
{
if(enemies[i].beacontimer.elapsed>=enemies[i].beacontime and enemies[i].dead==false)
{
enemies[i].beacontimer.restart();
p.play_3d("beacon",me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
}
}
if(get_tile_at(enemies[i].x,enemies[i].y,enemies[i].z)=="" and enemies[i].falling==false and enemies[i].type>6)
{
p.play_3d("fall",me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
enemies[i].falling=true;
enemies[i].x=enemies[i].x;
enemies[i].y=enemies[i].y;
enemies[i].z=enemies[i].z;
}
if(enemies[i].falling==true and enemies[i].falltimer.elapsed>=enemies[i].falltime)
{
enemies[i].falltimer.restart();
enemies[i].z-=1;
enemies[i].fallheight+=1;
if(get_tile_at(enemies[i].x,enemies[i].y,enemies[i].z)!="")
{
enemies[i].x=enemies[i].x;
enemies[i].y=enemies[i].y;
enemies[i].z=enemies[i].z;
enemies[i].falling=false;
if(enemies[i].fallheight>=10) p.play_3d(get_tile_at2(enemies[i].x,enemies[i].y,enemies[i].z)+"fall",me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,tilevolume,tilepitch,tilespeed,false);
else p.play_3d(get_tile_at2(enemies[i].x,enemies[i].y,enemies[i].z)+"land",me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,tilevolume,tilepitch,tilespeed,false);
enemies[i].fallheight=0;
}
}
if(enemies[i].shielded==1 and enemies[i].shieldshots<1)
{
p.play_3d("shieldbreak",me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
enemies[i].shielded=0;
}
if(enemies[i].cartridges==0 and enemies[i].weapon>=12)
{
if(enemies[i].type>6)
{
enemies[i].weapon=random(0,11);
p.play_3d(weapons[enemies[i].weapon].name+"draw",me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
}
else
{
enemies[i].cartridges+=random(10,100);
}
}
if(enemies[i].cartridges>=1 and enemies[i].weapon<12)
{
if(enemies[i].type==1) enemies[i].weapon=random(46,64);
else if(enemies[i].type==2) enemies[i].weapon=random(73,74);
else if(enemies[i].type==3) enemies[i].weapon=random(68,72);
else if(enemies[i].type==4) enemies[i].weapon=random(15,45);
else if(enemies[i].type==5) enemies[i].weapon=random(2,6);
else if(enemies[i].type==6) enemies[i].weapon=random(2,3);
else enemies[i].weapon=random(12,67);
p.play_3d(weapons[enemies[i].weapon].name+"draw",me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
}
if(enemies[i].ammo<1 and enemies[i].reloading==false and enemies[i].cartridges>0)
{
int n=random(1,2);
if(n==1)
{
if(enemies[i].type>6) p.play_3d(weapons[enemies[i].weapon].name+"reload",me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
enemies[i].reloading=true;
enemies[i].reloadtimer.restart();
}
else if(n==2)
{
if(enemies[i].type==1) enemies[i].weapon=random(46,64);
else if(enemies[i].type==2) enemies[i].weapon=random(73,74);
else if(enemies[i].type==3) enemies[i].weapon=random(68,72);
else if(enemies[i].type==4) enemies[i].weapon=random(15,45);
else if(enemies[i].type==5) enemies[i].weapon=random(2,6);
else if(enemies[i].type==6) enemies[i].weapon=random(2,3);
else
{
enemies[i].weapon=random(0,67);
p.play_3d(weapons[enemies[i].weapon].name+"draw",me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
}
}
}
if(enemies[i].reloadtimer.elapsed>=weapons[enemies[i].weapon].reloadtime and enemies[i].reloading==true and enemies[i].can_move==true)
{
enemies[i].ammo=weapons[enemies[i].weapon].maxammo;
enemies[i].cartridges-=1;
enemies[i].reloading=false;
}
if(enemies[i].stunned==true and enemies[i].stuntimer.elapsed>=enemies[i].stuntime)
{
enemies[i].stunned=false;
}
if(enemies[i].dx==-1 and enemies[i].dy==-1 and enemies[i].dz==-1)
{
enemies[i].target=random(0,enemies.length()-1);
if(enemies[i].target==i)
{
enemies[i].target=-1;
}
if(enemies[i].target==-1)
{
enemies[i].dx=me.x;
enemies[i].dy=me.y;
enemies[i].dz=me.z;
}
else
{
enemies[i].dx=enemies[enemies[i].target].x;
enemies[i].dy=enemies[enemies[i].target].y;
enemies[i].dz=enemies[enemies[i].target].z;
}
}
if(enemies[i].target>=enemies.length())
{
enemies[i].target=random(0,enemies.length()-1);
if(enemies[i].target==i)
{
enemies[i].target=-1;
}
if(enemies[i].target==-1)
{
enemies[i].dx=me.x;
enemies[i].dy=me.y;
enemies[i].dz=me.z;
}
else
{
enemies[i].dx=enemies[enemies[i].target].x;
enemies[i].dy=enemies[enemies[i].target].y;
enemies[i].dz=enemies[enemies[i].target].z;
}
}
if(enemies[i].target!=-1)
{
enemies[i].dx=enemies[enemies[i].target].x;
enemies[i].dy=enemies[enemies[i].target].y;
enemies[i].dz=enemies[enemies[i].target].z;
enemies[i].onplayer=false;
}
else if(enemies[i].target==-1)
{
enemies[i].dx=me.x;
enemies[i].dy=me.y;
enemies[i].dz=me.z;
enemies[i].onplayer=true;
}
if(enemies[i].dx>enemies[i].x-weapons[enemies[i].weapon].range and enemies[i].dx<enemies[i].x+weapons[enemies[i].weapon].range and enemies[i].dy>enemies[i].y-weapons[enemies[i].weapon].range and enemies[i].dy<enemies[i].y+weapons[enemies[i].weapon].range and enemies[i].z==enemies[i].z and enemies[i].attacktimer.elapsed>=(weapons[enemies[i].weapon].time) and enemies[i].dead==false and (enemies[i].weapon>=12 and enemies[i].ammo>0 or enemies[i].weapon<12) and enemies[i].type!=5 and enemies[i].type!=6 and enemies[i].can_move==true)
{
enemies[i].attacktimer.restart();
enemies[i].useitem=random(1, 100);
if(enemies[i].useitem==1 and (enemies[i].type>6?enemies[i].timebombs>=0:enemies[i].health>random(1000,5000)))
{
string owner;
if(enemies[i].type==1) owner="a police";
else if(enemies[i].type==2) owner="a tank";
else if(enemies[i].type==3) owner="an aircraft";
else if(enemies[i].type==4) owner="a helicopter";
else if(enemies[i].type==5) owner="a vehicle";
else if(enemies[i].type==6) owner="a bus";
else owner="an enemy";
spawn_timebomb(enemies[i].x,enemies[i].y,enemies[i].z,owner);
if(enemies[i].type>6) enemies[i].timebombs--;
}
else if(enemies[i].useitem==2 and (enemies[i].type>6?enemies[i].mines>=0:enemies[i].health>random(1000,5000)))
{
string owner;
if(enemies[i].type==1) owner="a police";
else if(enemies[i].type==2) owner="a tank";
else if(enemies[i].type==3) owner="an aircraft";
else if(enemies[i].type==4) owner="a helicopter";
else if(enemies[i].type==5) owner="a vehicle";
else if(enemies[i].type==6) owner="a bus";
else owner="an enemy";
if(enemies[i].facing==Left) spawn_mine(enemies[i].x-2,enemies[i].y,enemies[i].z,owner);
else if(enemies[i].facing==Right) spawn_mine(enemies[i].x+2,enemies[i].y,enemies[i].z,owner);
else if(enemies[i].facing==Backward) spawn_mine(enemies[i].x,enemies[i].y-2,enemies[i].z,owner);
else if(enemies[i].facing==Forward) spawn_mine(enemies[i].x,enemies[i].y+2,enemies[i].z,owner);
else
{
int where=random(1,4);
if(where==1) spawn_mine(enemies[i].x-random(2,2),enemies[i].y,enemies[i].z,owner);
else if(where==2) spawn_mine(enemies[i].x+random(2,2),enemies[i].y,enemies[i].z,owner);
else if(where==3) spawn_mine(enemies[i].x,enemies[i].y-random(2,2),enemies[i].z,owner);
else if(where==4) spawn_mine(enemies[i].x,enemies[i].y+random(2,2),enemies[i].z,owner);
}
if(enemies[i].type>6) enemies[i].mines--;
}
else if(enemies[i].useitem==3 and (enemies[i].type>6?enemies[i].molotov_cocktails>=0:enemies[i].health>random(1000,5000)))
{
string owner;
if(enemies[i].type==1) owner="a police";
else if(enemies[i].type==2) owner="a tank";
else if(enemies[i].type==3) owner="an aircraft";
else if(enemies[i].type==4) owner="a helicopter";
else if(enemies[i].type==5) owner="a vehicle";
else if(enemies[i].type==6) owner="a bus";
else owner="an enemy";
spawn_bullet(weapons[75].damage,weapons[75].range,enemies[i].x,enemies[i].y,enemies[i].z,enemies[i].facing,weapons[75].speed,i,75,owner);
if(enemies[i].type>6) enemies[i].molotov_cocktails--;
}
else if(enemies[i].useitem==4 and (enemies[i].type>6?enemies[i].turrets>=0:enemies[i].health>random(1000,5000)))
{
p.play_3d("turretplace",me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
enemies[i].can_move=false;
if(enemies[i].turrettimer.elapsed>12768)
{
enemies[i].turrettimer.restart();
string owner;
if(enemies[i].type==1) owner="a police";
else if(enemies[i].type==2) owner="a tank";
else if(enemies[i].type==3) owner="an aircraft";
else if(enemies[i].type==4) owner="a helicopter";
else if(enemies[i].type==5) owner="a vehicle";
else if(enemies[i].type==6) owner="a bus";
else owner="an enemy";
spawn_turret(enemies[i].x,enemies[i].y,enemies[i].z,owner);
enemies[i].can_move=true;
enemies[i].turrets--;
enemies[i].weapon=random(0,67);
}
}
else if(enemies[i].useitem==5 and (enemies[i].type>6?enemies[i].item_grabbers>=0:enemies[i].health<random(100,500)))
{
enemies[i].itemgrabber=true;
}
else if(enemies[i].useitem==6 and (enemies[i].type>6?enemies[i].grenades>=0:enemies[i].health>random(1000,5000)))
{
string owner;
if(enemies[i].type==1) owner="a police";
else if(enemies[i].type==2) owner="a tank";
else if(enemies[i].type==3) owner="an aircraft";
else if(enemies[i].type==4) owner="a helicopter";
else if(enemies[i].type==5) owner="a vehicle";
else if(enemies[i].type==6) owner="a bus";
else owner="an enemy";
spawn_bullet(weapons[76].damage,weapons[76].range,enemies[i].x,enemies[i].y,enemies[i].z,enemies[i].facing,weapons[76].speed,i,76,owner);
if(enemies[i].type>6) enemies[i].grenades--;
}
if(weapons[enemies[i].weapon].name=="knife") p.play_3d("knife"+random(1,4),me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
else if(weapons[enemies[i].weapon].name=="blake_sword") p.play_3d("blake_sword"+random(1,7),me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
else if(weapons[enemies[i].weapon].name=="short_sword" or weapons[enemies[i].weapon].name=="long_sword" or weapons[enemies[i].weapon].name=="stp106_long_barreled_pistol" or weapons[enemies[i].weapon].name=="grenade_launcher" or weapons[enemies[i].weapon].name=="cannon2") p.play_3d(weapons[enemies[i].weapon].name+""+random(1,3),me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
else p.play_3d(weapons[enemies[i].weapon].name,me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
distpool.play_3d(weapons[enemies[i].weapon].name+"dist",me.x,me.y,me.z,enemies[i].x,enemies[i].y,enemies[i].z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
string owner;
if(enemies[i].type==1) owner="a police";
else if(enemies[i].type==2) owner="a tank";
else if(enemies[i].type==3) owner="an aircraft";
else if(enemies[i].type==4) owner="a helicopter";
else if(enemies[i].type==5) owner="a vehicle";
else if(enemies[i].type==6) owner="a bus";
else owner="an enemy";
spawn_bullet(weapons[enemies[i].weapon].damage,weapons[enemies[i].weapon].range,enemies[i].x,enemies[i].y,enemies[i].z,enemies[i].facing,weapons[enemies[i].weapon].speed,i,enemies[i].weapon,owner);
if(weapons[enemies[i].weapon].maxammo>0)
{
enemies[i].ammo-=1;
}
else if(enemies[i].useitem==7 and (enemies[i].type>6?enemies[i].sandbags>=0:enemies[i].health>random(1000,5000)))
{
string owner;
if(enemies[i].type==1) owner="a police";
else if(enemies[i].type==2) owner="a tank";

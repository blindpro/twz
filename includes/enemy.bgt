attackrange=0;
damage=0;
attacktime=0;
shielded=0;
shieldshots=0;
voice.load_looped("bus"+random(1,4));
voice.play();
}
else if(invehicle=="police car")
{
x=ex;
y=ey;
z=ez;
health=0;
seerange=0;
weapon=random(46,64);
hasammo=weapons[weapon].hasammo;

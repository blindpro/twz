enemy(int t, int ex, int ey, int ez, string einvehicle="")
{
type=t;
invehicle=einvehicle;
if(type==1)
{
x=ex;
y=ey;
z=ez;
health=random(1000,10000);
seerange=random(15,25);
weapon=random(46,64);
hasammo=weapons[weapon].hasammo;
cartridges=random(10,50);
attackrange=weapons[weapon].range;
damage=weapons[weapon].damage;
attacktime=weapons[weapon].time;
shielded=0;
shieldshots=0;
voice.load_looped("police"+random(1,7));
voice.play();
}
else if(type==2)
{
x=ex;
y=ey;
z=ez;
health=random(5000,25000);
seerange=random(5,15);
weapon=random(73,74);
hasammo=weapons[weapon].hasammo;
cartridges=random(10,50);
attackrange=weapons[weapon].range;
damage=weapons[weapon].damage;
attacktime=weapons[weapon].time;
shielded=0;
shieldshots=0;
voice.load_looped("tank"+random(1,4));
voice.play();
}
else if(type==3)
{
x=ex;
y=ey;
z=ez+random(1,4);
health=random(1000,15000);

int health;
int movetime=random(180,300);
int type;
timer beacontimer, falltimer, reloadtimer, attacktimer, movetimer, dirtimer, burntimer, turrettimer, item_grabbertimer, enemy_grabbertimer, stuntimer, stunagaintimer, unstuntrytimer;;
double x,y,z;
string hitby="";
string hitby2="";
string hitbyweapon="";
int shielded;
int shieldshots;
sound_object voice, burnloop, item_grabberloop, enemy_grabberloop;

continue;
}
else if (key_down(KEY_RSHIFT) and key_pressed(KEY_5) and get_item_count()>=18) {
menu_position=18;
speak_item=true;
continue;
}
else if (key_down(KEY_RSHIFT) and key_pressed(KEY_6) and get_item_count()>=19) {
menu_position=19;
speak_item=true;
continue;
}
else if (key_down(KEY_RSHIFT) and key_pressed(KEY_7) and get_item_count()>=20) {
menu_position=20;
speak_item=true;
continue;
}
else if (key_down(KEY_RSHIFT) and key_pressed(KEY_8) and get_item_count()>=21) {
menu_position=21;
speak_item=true;
continue;
}
else if (key_down(KEY_RSHIFT) and key_pressed(KEY_9) and get_item_count()>=22) {
menu_position=22;
speak_item=true;
continue;
}
else if (key_down(KEY_RSHIFT) and key_pressed(KEY_0) and get_item_count()>=23) {
menu_position=23;
speak_item=true;
continue;
}
else if (key_down(KEY_RSHIFT) and key_pressed(KEY_MINUS) and get_item_count()>=24) {
menu_position=24;
speak_item=true;
continue;
}
else if (key_down(KEY_RSHIFT) and key_pressed(KEY_EQUALS) and get_item_count()>=25) {
menu_position=25;
speak_item=true;
continue;
}
else if (key_down(KEY_RSHIFT) and key_pressed(KEY_BACK) and get_item_count()>=26) {
menu_position=26;
speak_item=true;
continue;
}
}
if(enable_enter==true and key_pressed(KEY_RETURN) or enable_space==true and key_pressed(KEY_SPACE))
{
if(menu_position!=0)
{
if(srcs.is_playing()) srcs.stop();
if (item_list[menu_position-1].activate==true)
{
running=false;
return menu_position;
}
}
}
if(allow_escape==true)
{
if(key_pressed(KEY_ESCAPE) or key_pressed(KEY_BACK))
{
if(srcs.is_playing()) srcs.close();
if(internal_sound.is_playing()) internal_sound.close();
running=false;
return 0;
}
}
if(enable_up_and_down==true and key_up(KEY_LMENU) and key_up(KEY_RMENU) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_UP)==false and up.pressing())
{
initial=false;
if(menu_position==0)
{
menu_position=item_count;
speak_item=true;
continue;
}
if(menu_position==1)
{
if(wrap==true)
{
menu_position=item_count;
speak_item=true;
continue;
}
else
{
if (click_at_edge==true)
{
}
if (repeat_items_at_edges==true)
{
speak_item=true;
}
continue;
}
}
menu_position-=1;
speak_item=true;
continue;
}
if (enable_left_and_right==true and key_up(KEY_LMENU) and key_up(KEY_RMENU) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_LEFT)==false and left.pressing())
{
initial=false;
if(menu_position==0)
{
menu_position=item_count;
speak_item=true;
continue;
}
if(menu_position==1)
{
if(wrap==true)
{
menu_position=item_count;
speak_item=true;
continue;
}
else
{
if (click_at_edge==true)
{
}
if (repeat_items_at_edges==true)
{
speak_item=true;
}
continue;
}
}
menu_position-=1;
speak_item=true;
continue;
}
if(enable_up_and_down==true and key_pressed(KEY_UP)==false and up.pressing() or enable_left_and_right==true and key_pressed(KEY_LEFT)==false and left.pressing())
{
initial=false;
if(menu_position==0)
{
menu_position=item_count;
speak_item=true;
continue;
}
if(menu_position==1)
{
if(wrap==true)
{
menu_position=item_count;
speak_item=true;
continue;
}
else
{
if (click_at_edge==true)
{
}
if (repeat_items_at_edges==true)
{
speak_item=true;
}
continue;
}
}
menu_position-=1;
speak_item=true;
continue;
}
if(enable_up_and_down==true and key_pressed(KEY_DOWN)==false and down.pressing() or enable_left_and_right==true and key_pressed(KEY_RIGHT)==false and right.pressing())
{
initial=false;
if(menu_position==item_count)
{
if(wrap==true)
{
menu_position=1;
speak_item=true;
continue;
}
else
{
if (click_at_edge==true)
{
}
if (repeat_items_at_edges==true)
{
speak_item=true;
}
continue;
}
}
menu_position+=1;
speak_item=true;
continue;
}
if(enable_up_and_down==true and key_up(KEY_LMENU) and key_up(KEY_RMENU) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_DOWN)==false and down.pressing())
{
initial=false;
if(menu_position==item_count)
{
if(wrap==true)
{
menu_position=1;
speak_item=true;
continue;
}
else
{
if (click_at_edge==true)
{
}
if (repeat_items_at_edges==true)
{
speak_item=true;
}
continue;
}
}
menu_position+=1;
speak_item=true;
continue;
}
if (enable_left_and_right==true and key_up(KEY_LMENU) and key_up(KEY_RMENU) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_RIGHT)==false and right.pressing())
{
initial=false;
if(menu_position==item_count)
{
if(wrap==true)
{
menu_position=1;
speak_item=true;
continue;
}
else
{
if (click_at_edge==true)
{
}
if (repeat_items_at_edges==true)
{
speak_item=true;
}
continue;
}
}
menu_position+=1;
speak_item=true;
continue;
}
if(enable_home_and_end==true)
{
if(key_pressed(KEY_HOME))
{
initial=false;
menu_position=1;
speak_item=true;
continue;
}
if(key_pressed(KEY_END))
{
initial=false;
menu_position=item_count;
speak_item=true;
continue;
}
}
wait(5);
}
running=false;
return -1;
}

bool reset(bool completely)
{
if(running==true)
{
return false;
}
item_list.resize(0);
if(completely==true)
{
letters_autospeak=true;
letters_autoactivate=false;
speak_letter=false;
enable_first_letter_navigation=true;
click_at_edge=false;
repeat_items_at_edges=false;
enable_space=false;
enable_enter=true;
speak_position_information=false;
force_sapi=false;
enable_up_and_down=false;
enable_left_and_right=false;
wrap=true;
allow_escape=true;
enable_home_and_end=false;
speech_output=0;
@tts_handle=null;
@sound_handle=null;
@callback_handle=null;
}
return true;
}

// The following is private content and should not be modified from the outside.

tts_voice@ tts_handle;
sound_object@ sound_handle;
int speech_output;
menu_callback@ callback_handle;
string callback_data;
bool running;
int menu_position;
dynamic_menu_item[] item_list;

int add_item(string filename, bool is_filename, string name="", string key="", bool act=true, bool notgamesound=false)
{
if(running==true)
{
return -1;
}
int new_index=item_list.length();
item_list.resize(new_index+1);
item_list[new_index].option=filename;
item_list[new_index].is_filename=is_filename;
item_list[new_index].name=name;
item_list[new_index].activate=act;
item_list[new_index].notgamesound=notgamesound;
if (key=="")
{
key=filename[0];
key=string_to_lower_case(key);
}
item_list[new_index].letter=key;
return new_index+1;
}

}

double bconvert_to_pan(double length,double index, double range1, double range2)
{
if (length==1)
return 0;
double range=range2-range1;
double percent=index/(length-1);
double value=range1+range*percent;
return value;
}
funcdef int menu_callback(dynamic_menu_pro@, string);
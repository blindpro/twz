bullet@[] bullets(0);
class bullet
{
string owner="me";
string owner2="me";
int distance;
double x, y, z;
int facing;
int range;
int damage;
int speed=1;
timer speedtimer;
int weapon;
sound_object loop;
int spread=2;
bool hit=false;
bullet(int d, int r, int s1, int s2, int s3, int fa, int sp, string own="me", int we=w, string own2="")
{
weapon=we;
owner=own;
owner2=own2;
speed=sp;
facing=fa;
x=s1;
y=s2;
z=s3;
damage=d;
range=r;
if(weapons[weapon].name=="molotov_cocktail") p.play_3d("molotov_cocktailthrow",me.x,me.y,me.z,x,y,z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
if(weapons[weapon].name=="grenade_launcher" or weapons[weapon].name=="grenade")
{
loop.load_looped("grenaderoll");
loop.play();
}
else if(weapons[weapon].name=="rocket_launcher")
{
loop.load_looped("rocketwarn"+random(1,2));
loop.play();
}
else if(weapons[weapon].name=="missile_launcher")
{
loop.load_looped("missileloop"+random(1,3));
loop.play();
}
else if(weapons[weapon].name=="rpg_launcher" or weapons[weapon].name=="rpg7")
{
loop.load_looped("rpgloop");
loop.play();
}
else if(weapons[weapon].name=="cannon" or weapons[weapon].name=="cannon2")
{
loop.load_looped("cannon_ballloop");
loop.play();
}
}
}
void bulletloop()
{
for (uint i=0; i<bullets.length(); i++)
{
if(weapons[bullets[i].weapon].name=="grenade_launcher" or weapons[bullets[i].weapon].name=="grenade" or weapons[bullets[i].weapon].name=="rocket_launcher" or weapons[bullets[i].weapon].name=="missile_launcher" or weapons[bullets[i].weapon].name=="rpg_launcher" or weapons[bullets[i].weapon].name=="rpg7" or weapons[bullets[i].weapon].name=="cannon" or weapons[bullets[i].weapon].name=="cannon2") position_sound_3d(bullets[i].loop, me.x, me.y, me.z, bullets[i].x, bullets[i].y, bullets[i].z, facing, 10, 5, 5, 0, 100, 0);
if(bullets[i].speedtimer.elapsed>bullets[i].speed)
{
bullets[i].speedtimer.restart();
vector bull;

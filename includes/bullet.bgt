if(bullets[i].weapon<45 or bullets[i].weapon==52) bullets[i].hit=true;
}
}
}
if(bullets[i].hit)
{
if(weapons[bullets[i].weapon].name=="grenade_launcher" or weapons[bullets[i].weapon].name=="grenade" or weapons[bullets[i].weapon].name=="rocket_launcher" or weapons[bullets[i].weapon].name=="missile_launcher" or weapons[bullets[i].weapon].name=="rpg_launcher" or weapons[bullets[i].weapon].name=="rpg7" or weapons[bullets[i].weapon].name=="cannon" or weapons[bullets[i].weapon].name=="cannon2") bullets[i].loop.close();
@bullets[i]=null;
bullets.remove_at(i);
break;
}
}
}
}
void spawn_bullet(int p1, int p2, int p3, int p4, int p5, int p6, int p7, string own="me", int weapon=w, string own2="")
{
bullet b1(p1,p2,p3,p4,p5,p6,p7,own,weapon,own2);
bullets.insert_last(b1);
}
void destroy_all_bullets()
{
for (uint i=0; i<bullets.length(); i++)
{
bullets[i].loop.close();
}
bullets.resize(0);
}

{
name=n;
}
}
if(startlng==0)
{
if(question("would you like to select your language now?")==1)
{
string temp=langmenu();
if(temp=="")
{
speak("No action will be taken");
}
else
{
currentlangfile=temp;
startlng=1;
lngdata=file_get_contents("languages\\"+currentlangfile+" language.txt");
speak(""+currentlangfile+" is now your language");
}
}
else
{
startlng=1;
}
}
game();
}
void game()
{
setgamevolume(gamevolume);
load_map(mapname);
int n=random(2,74);
gameinv.give(weapons[n].name,1);
gameinv.give(weapons[n].ammotype,weapons[n].maxammo*random(1,5));
me.x=random(min.x,max.x);
me.y=random(min.y,max.y);
me.z=min.z;
for (uint i=0; i<random(2,10); i++)
{
if(mapname=="main")
{
spawn_blade(random(min.x,max.x),random(min.y,max.y),min.z,random(200,800),random(10,500),"bladeloop1","bladehit1");
}
}
playtimer.restart();
while(true)
{
wait(5);
mainloop();
if(inbicycle)
{
if(key_down(KEY_UP) and biketimer.elapsed>=400 and key_up(KEY_G))
{
biketimer.restart();
if(facing==0) bike.move_bicycle(Forward);
else if(facing==90) bike.move_bicycle(Right);
else if(facing==180) bike.move_bicycle(Backward);
else if(facing==270) bike.move_bicycle(Left);
}
if(key_down(KEY_DOWN) and biketimer.elapsed>=400 and key_up(KEY_G))
{
biketimer.restart();
if(facing==0) bike.move_bicycle(Backward);
else if(facing==90) bike.move_bicycle(Left);
else if(facing==180) bike.move_bicycle(Forward);
else if(facing==270) bike.move_bicycle(Right);
}
if(key_down(KEY_LEFT) and changerotationtimer.elapsed>=200 and key_up(KEY_G))
{
changerotationtimer.restart();
facing=snapleft(facing, getdir(facing), 90);
p.play_stationary("biketurn",0,100,0,0,false);
if(facing==135 or facing==270 or facing==180 or facing==0 or facing==315 or facing==45 or facing==90 or facing==225) speak(dir_to_string(getdir(facing)));
}
else if(key_down(KEY_RIGHT) and changerotationtimer.elapsed>=200 and key_up(KEY_G))
{
changerotationtimer.restart();
facing=snapright(facing, getdir(facing), 90);
p.play_stationary("biketurn",0,100,0,0,false);
if(facing==135 or facing==270 or facing==180 or facing==0 or facing==315 or facing==45 or facing==90 or facing==225) speak(dir_to_string(getdir(facing)));
}
if(key_pressed(KEY_SPACE) and biketimer.elapsed>=1000 and key_up(KEY_G))
{
biketimer.restart();
int number=random(1,5);
p.play_stationary("bike_bell"+number+"",0,100,0,0,false);
}
}
if(invehicle)
{
if(key_pressed(KEY_RETURN))
{
if(automobile.engine_on==false)
{
automobile.start_vehicle();
}
else
{
automobile.stop_vehicle();
}
}
if(key_down(KEY_PRIOR) and itsaircraft and automobile.engine_on and automobile.speedtimer.elapsed>=210 and key_up(KEY_G))
{
automobile.speedtimer.restart();
if(automobile.z<=max.z)
{
if(string_contains(get_tile_at(automobile.x,automobile.y,automobile.z),"wall",1)>-1)
{
p.play_stationary("vehicle_c"+random(1,6)+"",0,100,0,0,false);
gameinv.give(automobile.type,-1);
automobile.crashed=true;
}
if(automobile.crashed==false and automobile.z<max.z)
{
p.play_stationary("vehicleclick",0,100,0,0,false);
automobile.z++;
if(automobile.z>max.z)
automobile.z=max.z;
}
me.z=automobile.z;
automobile.check_radar(Up);
}
}
if(key_down(KEY_NEXT) and itsaircraft and automobile.engine_on and automobile.speedtimer.elapsed>=210 and key_up(KEY_G))
{
automobile.speedtimer.restart();
if(automobile.z>=min.z)
{
if(string_contains(get_tile_at(automobile.x,automobile.y,automobile.z),"wall",1)>-1)
{
p.play_stationary("vehicle_c"+random(1,6)+"",0,100,0,0,false);
gameinv.give(automobile.type,-1);
automobile.crashed=true;
}
if(automobile.crashed==false and automobile.z>min.z)
{
p.play_stationary("vehicleclick",0,100,0,0,false);
automobile.z--;
if(automobile.z<min.z)
automobile.z=min.z;
}
me.z=automobile.z;
automobile.check_radar(Down);
}
}
if(key_down(KEY_UP) and automobile.engine_on and automobile.speedtimer.elapsed>=automobile.speed and key_up(KEY_G))
{
automobile.speedtimer.restart();
if(facing==0) automobile.move_vehicle(Forward);
else if(facing==90) automobile.move_vehicle(Right);
else if(facing==180) automobile.move_vehicle(Backward);
else if(facing==270) automobile.move_vehicle(Left);
}
if((key_released(KEY_UP) or key_down(KEY_DOWN)) and automobile.engine_on and key_up(KEY_G))
{
automobile.move_vehicle();
}
if ((key_released(KEY_UP) or key_released(KEY_DOWN)) and automobile.engine_on)
{
automobile.slowable=true;
}
if(key_down(KEY_LEFT) and changerotationtimer.elapsed>=200 and key_up(KEY_G))
{
changerotationtimer.restart();
p.play_stationary("vehicleturn",0,100,0,0,false);
if(automobile.engine_on)
{
facing=snapleft(facing, getdir(facing), 90);
if(facing==135 or facing==270 or facing==180 or facing==0 or facing==315 or facing==45 or facing==90 or facing==225) speak(dir_to_string(getdir(facing)));
}
}
else if(key_down(KEY_RIGHT) and changerotationtimer.elapsed>=200 and key_up(KEY_G))
{
changerotationtimer.restart();
p.play_stationary("vehicleturn",0,100,0,0,false);
if(automobile.engine_on)
{
facing=snapright(facing, getdir(facing), 90);
if(facing==135 or facing==270 or facing==180 or facing==0 or facing==315 or facing==45 or facing==90 or facing==225) speak(dir_to_string(getdir(facing)));
}
}
if((key_down(KEY_LMENU) or key_down(KEY_RMENU)) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_W) and invehicle and itscar==true and automobile.type!="sky_racer" and automobile.type!="aircraft" and automobile.windowtimer.elapsed>=automobile.windowtime)
{
automobile.windowtimer.restart();
if(automobile.window==false)
{
p.play_stationary("vehicle_window_open",0,100,0,0,false);
resume_all_sources();
automobile.window=true;
}
else
{
p.play_stationary("vehicle_window_close",0,100,0,0,false);
pause_all_sources();
automobile.window=false;
}
}
}
if(key_pressed(KEY_F1) and itemgrabber==false and enemygrabber==false and turretplacing==false)
{
menu();
}
if(key_pressed(KEY_F2))
{
if(weaponpings==0)
{
weaponpings=1;
p.play_stationary("toggleon",0,100,0,0,false);
speak("weapon pings enabled");
}
else
{
weaponpings=0;
p.play_stationary("toggleoff",0,100,0,0,false);
speak("weapon pings disabled");
}
}
if(key_pressed(KEY_F12))
{
beep(1025);
copy_buffer_item();
}
if (key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_COMMA)==false and kcomma.pressing())
{
prevbufferitem();
}
if (key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_PERIOD)==false and kperiod.pressing())
{
nextbufferitem();
}
if (key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_LBRACKET)==false and klbracket.pressing())
{
bufferleft();
}
if (key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_RBRACKET)==false and krbracket.pressing())
{
bufferright();
}
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT) ) and key_pressed(KEY_COMMA))
{
topbufferitem();
}
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT) ) and key_pressed(KEY_PERIOD))
{
bottombufferitem();
}
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT) ) and key_pressed(KEY_LBRACKET))
{
firstbuffer();
}
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT) ) and key_pressed(KEY_RBRACKET))
{
lastbuffer();
}
if(key_pressed(KEY_H))
{
if(shielded) add_buffer_item("misc",health+" health, with "+shieldshots+" shielded shots");
else add_buffer_item("misc",health+" health");
}
if(key_pressed(KEY_Z))
{
add_buffer_item("zones","Current location: "+currentloc);
}
if(key_pressed(KEY_B))
{
buildermenu();
}
if((key_down(KEY_LMENU) or key_down(KEY_RMENU)) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_N))
{
if(trackx==-1 or tracky==-1 or trackz==-1 or tracking=="")
{
speak("Nothing to track");
}
else tell_where(trackx,tracky,trackz,"loctrack",false);
}
if(key_up(KEY_LMENU) and key_up(KEY_RMENU) and (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and key_pressed(KEY_N))
{
if(ttrackx==-1 or ttracky==-1 or ttrackz==-1 or ttracking=="")
{
speak("Nothing to track");
}
else tell_where(ttrackx,ttracky,ttrackz,"locttrack",false);
}
if(key_pressed(KEY_RETURN) and itemgrabber==false and enemygrabber==false and turretplacing==false)
{
for (uint i=0; i<objs.length(); i++)
{
if(get_3d_distance(me.x, me.y, me.z, objs[i].x, objs[i].y, objs[i].z)<=5)
{
objs[i].take();
objs.remove_at(i);
break;
}
}
for (uint i=0; i<stores.length(); i++)
{
if(me.x==stores[i].x and me.y==stores[i].y and me.z==stores[i].z)
{
p.play_stationary("store_door_open",0,100,0,0,false);
storemenu();
}
}
for (uint i=0; i<doors.length(); i++)
{
if(me.x>=doors[i].mindx and me.x<=doors[i].maxdx and me.y>=doors[i].mindy and me.y<=doors[i].maxdy and me.z>=doors[i].mindz and me.z<=doors[i].maxdz and dmoving==false)
{
if(doors[i].text!="nothing") speak(doors[i].text);
can_move=false;
if(doors[i].ds3!="silence") p.play_stationary(doors[i].ds3,0,100,0,0,false);
doors[i].doorsound2=p.play_stationary(doors[i].ds2, 0,100,0,0,true);
doors[i].moving=true;
dmoving=true;
}
}
for (uint i=0; i<travelpoints.length(); i++)
{
if (me.x>=travelpoints[i].mindx and me.x<=travelpoints[i].maxdx and me.y>=travelpoints[i].mindy and me.y<=travelpoints[i].maxdy and me.z>=travelpoints[i].mindz and me.z<=travelpoints[i].maxdz)
{
speak(travelpoints[i].text);
me.x=travelpoints[i].nx;
me.y=travelpoints[i].ny;
me.z=travelpoints[i].nz;
load_map(travelpoints[i].nmap);
}
}
for (uint i=0; i<enemies.length(); i++)
{
if((enemies[i].type==5 or enemies[i].type==6) and enemies[i].dead==false and get_3d_distance(me.x, me.y, me.z, enemies[i].x, enemies[i].y, enemies[i].z)<=5 and can_move==true and enemies[i].ride=="")
{
p.play_stationary("carpassengeron",0,100,0,0,false);
enemies[i].ride="me";
can_move=false;
}
else if((enemies[i].type==5 or enemies[i].type==6) and enemies[i].dead==false and enemies[i].ride=="me")
{
p.play_stationary("carpassengeroff",0,100,0,0,false);
enemies[i].ride="";
can_move=true;
}
}
}
if(key_pressed(KEY_T))
{
add_buffer_item("misc",ms_to_readable_time(playtimer.elapsed));
}
if(key_pressed(KEY_W) and w>=0 and weapons[w].reloading==false and itemgrabber==false and enemygrabber==false and turretplacing==false)
{
weaponmenu();
}
if(key_pressed(KEY_GRAVE))
{
if(w==0) w=1;
else w=0;
speak(weapons[w].name);
p.play_stationary(weapons[w].name+"draw",0,100,0,0,false);
}
if (key_pressed(KEY_R))
{
if (w>=0 and weapons[w].hasammo==true and weapons[w].reloading==false and weapons[w].ammo<=0 and gameinv.get_item_amount(weapons[w].ammotype)>=weapons[w].maxammo)
{
p.play_stationary(weapons[w].name+"reload",0,100,0,0,false);
weapons[w].reloadtimer.restart();
weapons[w].reloading=true;
}
}
if (w>0 and weapons[w].hasammo==true and weapons[w].reloadtimer.elapsed>=weapons[w].reloadtime and weapons[w].reloading==true)
{
weapons[w].reloading=false;
weapons[w].ammo=weapons[w].maxammo;
gameinv.give(weapons[w].ammotype,-weapons[w].maxammo);
}
if (key_pressed(KEY_A) and w>=0 and weapons[w].hasammo==true)
{
speak(weapons[w].ammo+" of "+weapons[w].maxammo+" "+weapons[w].ammotype+" loaded, and "+gameinv.get_item_amount(weapons[w].ammotype)+" "+(gameinv.get_item_amount(weapons[w].ammotype)==1?weapons[w].ammotype:weapons[w].ammotype+"s")+" in reserve");
}
if (key_down(KEY_LCONTROL) and can_move==true and w>=0 and weapontimer.elapsed>=weapons[w].time and weapons[w].automatic==true)
{
if (weapons[w].hasammo==true and weapons[w].ammo>0 or weapons[w].hasammo==false)
{
weapontimer.restart();
p.play_stationary(weapons[w].name,0,100,0,0,false);
spawn_bullet(weapons[w].damage,weapons[w].range,me.x,me.y,me.z,facing,weapons[w].speed,"me",w);
}
if (weapons[w].hasammo==true and weapons[w].ammo>0)
{
weapons[w].ammo-=1;
}
}
if (key_pressed(KEY_LCONTROL) and can_move==true and w>=0 and weapontimer.elapsed>=weapons[w].time)
{
if (weapons[w].hasammo==true and weapons[w].ammo>0 and weapons[w].automatic==false or weapons[w].hasammo==false and weapons[w].automatic==false)
{
weapontimer.restart();
if(weapons[w].name=="knife") p.play_stationary("knife"+random(1,4),0,100,0,0,false);
else if(weapons[w].name=="blake_sword") p.play_stationary("blake_sword"+random(1,7),0,100,0,0,false);
else if(weapons[w].name=="short_sword" or weapons[w].name=="long_sword" or weapons[w].name=="stp106_long_barreled_pistol" or weapons[w].name=="grenade_launcher" or weapons[w].name=="cannon2") p.play_stationary(weapons[w].name+""+random(1,3),0,100,0,0,false);
else p.play_stationary(weapons[w].name,0,100,0,0,false);
spawn_bullet(weapons[w].damage,weapons[w].range,me.x,me.y,me.z,facing,weapons[w].speed,"me",w);
}
if (weapons[w].hasammo==true and weapons[w].ammo>0)
{
weapons[w].ammo-=1;
}
else if (w>=0 and weapons[w].ammo==0 and weapons[w].hasammo==true and weapons[w].reloading==false)
{
p.play_stationary(weapons[w].name+"empty",0,100,0,0,false);
}
}
if(key_pressed(KEY_DELETE))
{
setupmenu();
m.add_item_tts("health","health");
m.add_item_tts("item","item");
m.add_item_tts("shielded shots","shieldshots");
m.add_item_tts("Go back","back");
int mres=m.run("Select a cheat",true);
if (mres==1)
{
double amount=string_to_number(input_box("","how many?"));
if(amount>0)
{
health=amount;
if(cheatmode==false) cheatmode=true;
}
}
else if (mres==2)
{
string itemname=input_box("","Type the item name and press enter");
if(itemname!="")
{
double amount=string_to_number(input_box("","how many?"));
if(amount>0)
{
gameinv.give(itemname,amount);
p.play_stationary("invgive"+random(1,2),0,100,0,0,false);
speak("you've received "+amount+" "+itemname);
if(cheatmode==false) cheatmode=true;
}
}
}
if (mres==3)
{
double amount=string_to_number(input_box("","how many?"));
if(amount>0)
{
if(shielded==false) shielded=true;
shieldshots=amount;
if(cheatmode==false) cheatmode=true;
}
}

}
if(key_up(KEY_LMENU) and key_up(KEY_RMENU) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_TAB))
{
gameinv.cycle(1);
}
if(key_up(KEY_LMENU) and key_up(KEY_RMENU) and (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and key_pressed(KEY_TAB))
{
gameinv.cycle(0);
}
if(key_pressed(KEY_BACK) and inbicycle==false and invehicle==false and can_move==true)
{
if(gameinv.items.length()==0)
{
speak("No item");
}
else
{
if(gameinv.invpos>=0 and gameinv.invpos<=gameinv.items.length()-1)
{
useitem(gameinv.items[gameinv.invpos].name);
}
}
}
if(key_down(KEY_BACK) and gameinv.items.length()>0 and gameinv.invpos>=0 and gameinv.invpos<=gameinv.items.length()-1 and gameinv.items[gameinv.invpos].name=="grenade" and grenadethrow==false)
{
p.play_stationary("grenadepull",0,100,0,0,false);
grenadethrowtimer.restart();
grenadethrow=true;
}
if(key_released(KEY_BACK) and gameinv.items.length()>=0 and gameinv.invpos>=0 and gameinv.invpos<=gameinv.items.length()-1 and gameinv.items[gameinv.invpos].name=="grenade" and grenadethrow==true)
{
p.play_stationary("grenadethrow",0,100,0,0,false);
spawn_bullet(weapons[76].damage,weapons[76].range,me.x,me.y,me.z,facing,weapons[76].speed,"me",76);
grenadethrow=false;
gameinv.give("grenade",-1);
}
if((key_down(KEY_LMENU) or key_down(KEY_RMENU)) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_V))
{
string stext=input_box("","Type the  item  name");
if(stext!="")
{
int search=gameinv.search_inv(stext);
if(search==-1)
{
speak("No items found matching your search keywords");
}
else
{
gameinv.invpos=search;
speak(gameinv.items[gameinv.invpos].name+": "+gameinv.items[gameinv.invpos].amount+". "+gameinv.invpos+" of "+gameinv.items.length());
}
}
}
if(key_up(KEY_LMENU) and key_up(KEY_RMENU) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_I) and get_tile_at(me.x, me.y, me.z)!="underwater")
{
if(gameinv.items.length()==0)
{
speak("you can't open your empty inventory");
}
else if(get_tile_at(me.x, me.y, me.z)=="" or get_tile_at(me.x, me.y, me.z)=="air")
{
speak("you can't open your inventory in the air");
}
else
{
invmenu();
}
}
if(key_pressed(KEY_SPACE) and !jumping and !falling and get_tile_at(me.x, me.y, me.z+1)=="" and can_move==true and invehicle==false and inbicycle==false and max.z!=0 and me.z<=max.z)
{
p.play_stationary("jump",0,100,0,0,false);
jumping=true;
rising=true;
}
if(key_up(KEY_LMENU) and key_up(KEY_RMENU) and key_pressed(KEY_SPACE) and jumping==false and falling==false and can_move==true  and inbicycle==false)
{
if(invehicle)
{
if(itscar)
{
if(automobile.type=="ford") horn5.play();
else if(automobile.type=="sorento") horn2.play();
else if(automobile.type=="grayhound_bus") horn7.play();
else if(automobile.type=="truck") horn7.play();
else if(automobile.type=="ford_pickup_truck") horn7.play();
else if(automobile.type=="v4_by_4_jeep") horn6.play();
else if(automobile.type=="dodge_charger") horn4.play();
else if(automobile.type=="dogan_slx") horn3.play();
else if(automobile.type=="doom_buggy") horn5.play();
else if(automobile.type=="mlk_mission_cruiser") horn7.play();
else horn1.play();
}
else if(itscar==false)
{
horn8.play();
}
}
}
if (key_released(KEY_SPACE) and inbicycle==false)
{
if(invehicle)
{
if(itscar)
{
if(automobile.type=="ford") horn5.stop();
else if(automobile.type=="sorento") horn2.stop();
else if(automobile.type=="grayhound_bus") horn7.stop();
else if(automobile.type=="truck") horn7.stop();
else if(automobile.type=="ford_pickup_truck") horn7.stop();
else if(automobile.type=="v4_by_4_jeep") horn6.stop();
else if(automobile.type=="dodge_charger") horn4.stop();
else if(automobile.type=="dogan_slx") horn3.stop();
else if(automobile.type=="doom_buggy") horn5.stop();
else if(automobile.type=="mlk_mission_cruiser") horn7.stop();
else horn1.stop();
}
else if(itscar==false)
{
horn8.stop();
}
}
}
if(key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_HOME)==false and khome.pressing() and gamevolume<10000)
{
gamevolume+=1000;
setgamevolume(gamevolume);
}

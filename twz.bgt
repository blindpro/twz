string generate_token(int token_length)
{
string token_sims="1234567890qQwWeErRtTyYuUiIoOpPaAsSdDfFgGhHjJkKlLzZxXcCvVbBnNmM";
string final_token;
for(uint i=0; i<token_length; i++)
{
final_token+=token_sims[random(0, token_sims.length()-1)];
}
return final_token;
}
string langmenu()
{
if(!directory_exists("languages"))
{
dlg("Could not find languages");
return "";
}
string[] lngfiles=find_files("languages/*.txt");
if(lngfiles.length<=0)
{
dlg("No languages found");
return "";
}
setupmenu();
m.speak_position_information=true;
for(uint i=0; i<lngfiles.length; i++)
{
if(string_contains(lngfiles[i]," language.txt",1)>-1)
{
m.add_item_tts(string_replace(lngfiles[i]," language.txt","",true),lngfiles[i]);
}
}
m.add_item_tts("go back","back");
int mres=m.run("select your language",true);
if(mres<=0)
{
return "";
}
else return string_trim_right(m.get_item_name(mres),4);
}
void combocheck(string combonumber)
{
string[] lines=string_split(combolist,"\r\n",false);
for(uint i=0; i<lines.length(); i++)
{
if(lines[i].is_empty()) continue;
if(lines.length()<1) continue;
if(string_contains(lines[i],":",1)<0) continue;
if(string_contains(lines[i],"::",1)>-1) continue;
string[] comboparsed=string_split(lines[i], ":", true);
if(comboparsed.length()<2) continue;
if(combonumber==comboparsed[1])
{
combo2(comboparsed[0],comboparsed[2],string_to_number(comboparsed[3]),comboparsed[4],string_to_number(comboparsed[5]),string_to_number(comboparsed[6]));
}
}
}
void combo(string combo, int firetime)
{
if(combofiretimer.elapsed>firetime)
{
combofiretimer.restart();
p.play_stationary(combo+""+random(1,3),0,100,0,0,false);
if(combo=="light_punch") spawn_bullet(weapons[77].damage,weapons[77].range,me.x,me.y,me.z,facing,weapons[77].speed,"me",77);
else if(combo=="punch") spawn_bullet(weapons[78].damage,weapons[78].range,me.x,me.y,me.z,facing,weapons[78].speed,"me",78);
else if(combo=="heavy_punch") spawn_bullet(weapons[79].damage,weapons[79].range,me.x,me.y,me.z,facing,weapons[79].speed,"me",79);
else if(combo=="light_kick") spawn_bullet(weapons[80].damage,weapons[80].range,me.x,me.y,me.z,facing,weapons[80].speed,"me",80);
else if(combo=="kick") spawn_bullet(weapons[81].damage,weapons[81].range,me.x,me.y,me.z,facing,weapons[81].speed,"me",81);
else if(combo=="heavy_kick") spawn_bullet(weapons[82].damage,weapons[82].range,me.x,me.y,me.z,facing,weapons[82].speed,"me",82);
else if(combo=="grab") spawn_bullet(weapons[83].damage,weapons[83].range,me.x,me.y,me.z,facing,weapons[83].speed,"me",83);
else if(combo=="throw") spawn_bullet(weapons[84].damage,weapons[84].range,me.x,me.y,me.z,facing,weapons[84].speed,"me",84);
else if(combo=="slam") spawn_bullet(weapons[85].damage,weapons[85].range,me.x,me.y,me.z,facing,weapons[85].speed,"me",85);
}
}
void combo2(string combo, string sound, double health, string action, int stuntime, int throwdistance)
{
speak(combo);
for(uint i2=0; i2<enemies.length(); i2++)
{
if(get_3d_distance(me.x, me.y, me.z, enemies[i2].x, enemies[i2].y, enemies[i2].z)<=7 and enemies[i2].dead==false and enemies[i2].type>6)
{
p.play_3d(sound,me.x,me.y,me.z,enemies[i2].x,enemies[i2].y,enemies[i2].z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
int t=enemies[i2].type-6;
p.play_3d("enemy"+t+"pain"+random(1,3),me.x,me.y,me.z,enemies[i2].x,enemies[i2].y,enemies[i2].z,facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
enemies[i2].health-=health;
enemies[i2].hitby="me";
enemies[i2].hitby2="me";
enemies[i2].hitbyweapon=combo;
if(action=="stun" and stuntime>0)
{
enemies[i2].stun(stuntime);
}
if(action=="throw_up" and throwdistance>0)
{
enemies[i2].x=enemies[i2].x;
enemies[i2].y=enemies[i2].y+throwdistance;
enemies[i2].z=enemies[i2].z+throwdistance;
enemies[i2].falling=true;
}
}
}
}

facing=snapleft(facing, getdir(facing), 90);
p.play_stationary("turn",0,100,0,0,false);
if(facing==90 or facing==180 or facing==270 or facing==0) speak(dir_to_string(getdir(facing)));
}
else if((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and key_up(KEY_LMENU) and key_up(KEY_RMENU) and key_down(KEY_E) and changerotationtimer.elapsed>=changerotationtime and !inbicycle and !invehicle)
{
changerotationtimer.restart();
facing=snapright(facing, getdir(facing), 90);
p.play_stationary("turn",0,100,0,0,false);
if(facing==90 or facing==180 or facing==270 or facing==0) speak(dir_to_string(getdir(facing)));
}
if((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and (key_down(KEY_LMENU) or key_down(KEY_RMENU)) and key_down(KEY_Q) and changerotationtimer.elapsed>=changerotationtime and !inbicycle and !invehicle)
{
changerotationtimer.restart();
facing=turnleft(facing, 1);
p.play_stationary("turn",0,100,0,0,false);
speak(dir_to_string(getdir(facing))+" at "+facing+"degrees");
}
else if((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and (key_down(KEY_LMENU) or key_down(KEY_RMENU)) and key_down(KEY_E) and changerotationtimer.elapsed>=changerotationtime and !inbicycle and !invehicle)
{
changerotationtimer.restart();
facing=turnright(facing, 1);
p.play_stationary("turn",0,100,0,0,false);
speak(""+dir_to_string(getdir(facing))+" at "+facing+"degrees");
}
if(key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_up(KEY_LMENU) and key_up(KEY_RMENU) and key_down(KEY_Q) and changerotationtimer.elapsed>=changerotationtime and !inbicycle and !invehicle)
{
changerotationtimer.restart();
facing=snapleft(facing, getdir(facing), 45);
p.play_stationary("turn",0,100,0,0,false);
if(facing==135 or facing==270 or facing==180 or facing==0 or facing==315 or facing==45 or facing==90 or facing==225) speak(dir_to_string(getdir(facing)));
}
else if(key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_up(KEY_LMENU) and key_up(KEY_RMENU) and key_down(KEY_E) and changerotationtimer.elapsed>=changerotationtime and !inbicycle and !invehicle)
{
changerotationtimer.restart();
facing=snapright(facing, getdir(facing), 45);
p.play_stationary("turn",0,100,0,0,false);
if(facing==135 or facing==270 or facing==180 or facing==0 or facing==315 or facing==45 or facing==90 or facing==225) speak(dir_to_string(getdir(facing)));
}
if(key_up(KEY_LMENU) and key_up(KEY_RMENU) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_F))
{
speak("facing "+dir_to_string(getdir(facing))+" at "+facing+" degrees");
}
if(key_up(KEY_LMENU) and key_up(KEY_RMENU) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_K))
{
add_buffer_item("misc",kills+" "+(kills==1?"kill":"kills"));
}
if(key_up(KEY_LMENU) and key_up(KEY_RMENU) and (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and key_pressed(KEY_K))
{
checkarroundtilesmenu();
}
if((key_down(KEY_LMENU) or key_down(KEY_RMENU)) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_K))
{
checkarroundmenu();
}
if(can_move and !inbicycle and !invehicle)
{
if(key_down(KEY_PRIOR) and movetimer.elapsed>=walktime)
{
movetimer.restart();
move(Up);
if(magnetic_shoes==true) objcheck();
}
if(key_down(KEY_NEXT) and movetimer.elapsed>=walktime)
{
movetimer.restart();
move(Down);
if(magnetic_shoes==true) objcheck();
}
if(key_down(KEY_DOWN) and movetimer.elapsed>=walktime)
{
movetimer.restart();
move(Backward);
if(magnetic_shoes==true) objcheck();
}
if(key_down(KEY_UP) and movetimer.elapsed>=walktime)
{
movetimer.restart();
move(Forward);
if(magnetic_shoes==true) objcheck();
}
if(key_down(KEY_LEFT) and movetimer.elapsed>=walktime)
{
movetimer.restart();
move(Left);
if(magnetic_shoes==true) objcheck();
}
if(key_down(KEY_RIGHT) and movetimer.elapsed>=walktime)
{
movetimer.restart();
move(Right);
if(magnetic_shoes==true) objcheck();
}
}
if(key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_C))
{
add_buffer_item("misc",round(me.x,0)+", "+round(me.y,0)+", "+round(me.z,0));
}
if((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and key_pressed(KEY_C))
{
for (uint i=0; i<stores.length(); i++)
{
add_buffer_item("misc","the store is at "+round(stores[i].x,0)+", "+round(stores[i].y,0)+", "+round(stores[i].z,0));
}
}
if(key_pressed(KEY_ESCAPE))
{
if(inbicycle)
{
p.play_stationary("bikeoff",0,100,0,0,false);
inbicycle=false;
can_move=true;
}
else if(invehicle)
{
automobile.engine.stop();
if(itsaircraft)
{
resume_all_sources();
p.play_stationary(automobile.type+"_unspawn",0,100,0,0,false);
itsaircraft=false;
}
else if(itscar)
{
resume_all_sources();
p.play_stationary(automobile.type+"_unspawn",0,100,0,0,false);
automobile.window=false;
itscar=false;
}
else
{
p.play_stationary("generic_motorcycle_unspawn",0,100,0,0,false);
}
automobile.type="";
automobile.fuel=0;
automobile.speed=0;
invehicle=false;
can_move=true;
}
else
{
if(question("Are you sure you want to exit?")==1)
{
writeprefs();
exit();
}
}
}

}

}
void mainloop()
{
if(sources.length()>0) sourceloop();
if(musics.length()>0) musicloop();
if(enemies.length()>0) eloop();
if(bullets.length()>0) bulletloop();
if(objs.length()>0) icheckloop();
if(timebombs.length()>0) timebombloop();
if(fires.length()>0) fireloop();
if(mines.length()>0) mineloop();
if(stores.length()>0) storeloop();
if(turrets.length()>0) turretloop();
if(sandbags.length()>0) sandbagloop();
if(blades.length()>0) bladeloop();
if(doors.length()>0) doorloop();
if(invehicle and automobile.engine_on) automobile.loop();
checkloc();
p.update_listener_3d(me.x, me.y, me.z, facing*pi/180);
distpool.update_listener_3d(me.x, me.y, me.z, facing*pi/180);
if(health<=0)
{
srcs.close();
p.destroy_all;
if(bullets.length()>0) destroy_all_bullets();
if(enemies.length()>0) destroy_all_enemies();
if(objs.length()>0) destroy_all_objs();
if(timebombs.length()>0) destroy_all_timebombs();
if(mines.length()>0) destroy_all_mines();
if(fires.length()>0) destroy_all_fires();
if(stores.length()>0) destroy_all_stores();
if(turrets.length()>0) destroy_all_turrets();
if(sandbags.length()>0) destroy_all_sandbags();
if(doors.length()>0) destroy_all_doors();
if(travelpoints.length()>0) destroy_all_travelpoints();
if(blades.length()>0) destroy_all_blades();
if(sources.length()>0) destroy_all_sources();
if(musics.length()>0) destroy_all_musics();
background_music=0;
if(tiles.length()>0) tiles.resize(0);
if(zones.length()>0) zones.resize(0);
if(burned) burnloop.close();
dlgmeu("you have been killed!","death",true,25);
if(kills>0 and cheatmode==false)
{
if(question("You killed "+kills+" "+(kills==1?"person":"people")+". Do you want to post it in to the scoreboard?")==1) sboard.post_score(kills,playtimer.elapsed);
}
writeprefs();
exit();
}
if(shielded and shieldshots<1)
{
p.play_stationary("shieldbreak",0,100,0,0,false);
shielded=false;
}
if(grenadethrowtimer.elapsed>5000 and grenadethrow==true)
{
grenadethrowtimer.restart();
p.play_stationary("grenade_explode"+random(1,6),0,100,0,0,false);
health-=weapons[45].damage;
grenadethrow=false;
gameinv.give("grenade",-1);
}
if(burned)
{
if(burnsound==false)
{
burnloop.load_looped("fire"+random(1,7));
burnloop.play();
burnsound=true;
}
if(burntimer.elapsed>random(400,530))
{
burntimer.restart();
p.play_stationary("pain"+random(1,5),0,100,0,0,false);
health-=random(1,10);
burn++;
}
if(burn==random(25,35))
{
burnloop.close();
burnsound=false;
burned=false;
}
}
if(turretplacing==true and turrettimer.elapsed>12768)
{
turretplacing=false;
spawn_turret(me.x,me.y,me.z,"me");
gameinv.give("turret",-1);
can_move=true;
}
if(item_grabbersound==true and item_grabberstarttimer.elapsed>930)
{
item_grabberloop.load_looped("item_grabber");
item_grabberloop.play();
itemgrabber=true;
item_grabbersound=false;
}
if(itemgrabber==true and item_grabbersound==false and item_grabbertimer.elapsed>12000)
{
for (uint i=0; i<objs.length(); i++)
{
objs[i].x=me.x;
objs[i].y=me.y;
objs[i].z=me.z;
}
item_grabberloop.close();
p.play_stationary("item_grabberstop",0,100,0,0,false);
itemgrabber=false;
gameinv.give("item_grabber",-1);
can_move=true;
}
if(enemy_grabbersound==true and enemy_grabberstarttimer.elapsed>930)
{
enemy_grabberloop.load_looped("item_grabber");
enemy_grabberloop.play();
enemygrabber=true;
enemy_grabbersound=false;
}
if(enemygrabber==true and enemy_grabbersound==false and enemy_grabbertimer.elapsed>12000)
{
for (uint i=0; i<enemies.length(); i++)
{
enemies[i].x=me.x;
enemies[i].y=me.y;
enemies[i].z=me.z;
}
enemy_grabberloop.close();
p.play_stationary("item_grabberstop",0,100,0,0,false);
enemygrabber=false;
gameinv.give("enemy_grabber",-1);
can_move=true;
}
if(trackx!=-1 and tracky!=-1 and trackz!=-1 and tracking!="")
{
if(trackingtimer.elapsed>700)
{
trackingtimer.restart();
p.play_3d("loctrack", me.x, me.y, me.z, trackx, tracky, trackz, facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
}
if(currentloc==tracking)
{
p.play_stationary("loctracked",0,100,0,0,false);
trackx=-1; tracky=-1; trackz=-1; tracking="";
}
}
if(ttrackx!=-1 and ttracky!=-1 and ttrackz!=-1 and ttracking!="")
{
if(trackingtimer.elapsed>700)
{
trackingtimer.restart();
p.play_3d("loctrack", me.x, me.y, me.z, ttrackx, ttracky, ttrackz, facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
}
if(me.x==ttrackx and me.y==ttracky and me.z==ttrackz)
{
p.play_stationary("loctracked",0,100,0,0,false);
ttrackx=-1; ttracky=-1; ttrackz=-1; ttracking="";
}
}
if (spawntimer.elapsed>=spawntime)
{
spawntimer.restart();
spawn_enemy(random(1,maxenemies),random(min.x,max.x),random(min.y,max.y),min.z);
spawn_obj(random(min.x,max.x),random(min.y,max.y),min.z);
}
if(combokeys!="" and combotimer.elapsed>=300 and can_move==true)
{
combotimer.restart();
combocheck(combokeys);
combokeys="";
combotimer.pause();
}
if(jumping==true)
{
movetime=airtime;
}
else
{
movetime=walktime;
}
if(in_map and !jumping and !falling and get_tile_at(me.x, me.y, me.z)=="")
{
falling=true;
p.play_stationary("fall",0,100,0,0,false);
}
if(falling)
{
if(falltimer.elapsed>=falltime and me.z>0)
{
falltimer.restart();
me.z--;
fallcounter++;
}
if(get_tile_at(me.x, me.y, me.z)!="")
{
if(fallcounter<=jumphight)
p.play_stationary(get_tile_at2(me.x, me.y, me.z)+"land",0,tilevolume,tilepitch,tilespeed,false);
else if(fallcounter>jumphight)
{
health-=fallcounter;
p.play_stationary(get_tile_at2(me.x, me.y, me.z)+"fall",0,tilevolume,tilepitch,tilespeed,false);
}
falling=false;
fallcounter=0;
}
}
if(jumping)
{
if(rising and jumpcounter<jumphight and jumptimer.elapsed>=jumptime and get_tile_at(me.x, me.y, me.z+1)=="")
{
jumptimer.restart();
jumpcounter++;
me.z++;
}
if(jumpcounter>=jumphight)
{
rising=false;
lowering=true;
}
if(lowering and get_tile_at(me.x, me.y, me.z)=="" and falltimer.elapsed>=falltime and invehicle==false)
{
falltimer.restart();
jumpcounter--;
me.z--;
fallcounter++;
}
if(get_tile_at(me.x, me.y, me.z)!="")
{
rising=false;
lowering=false;
jumping=false;
if(fallcounter<=jumphight)
p.play_stationary(get_tile_at2(me.x, me.y, me.z)+"land",0,tilevolume,tilepitch,tilespeed,false);
else
{
health-=fallcounter;
p.play_stationary(get_tile_at(me.x, me.y, me.z)+"fall",0,100,0,0,false);
}
fallcounter=0;
jumpcounter=0;
}
}
}
void readprefs()
{
file f;
f.open("data.dat","rb");
string content=string_decrypt(f.read(),"jL20xusjz0vMYryg4UHntpgDuNl8lYy0");
string[] peramitors=string_split(content, "\r\n", true);
string[] values;
for(uint i=0; i<peramitors.length(); i++)
{
values.insert_at(i,string_replace(peramitors[i], string_left(peramitors[i], string_contains(peramitors[i], "=", 1)+1), "", true));
peramitors[i]=string_replace(peramitors[i], "="+values[i], "", true);
}
if(peramitors.find("name")!=-1)
{
name=values[peramitors.find("name")];
}
if(peramitors.find("VC_redistx86")!=-1)
{
VC_redistx86=string_to_number(values[peramitors.find("VC_redistx86")]);
}
if(peramitors.find("weaponpings")!=-1)
{
weaponpings=string_to_number(values[peramitors.find("weaponpings")]);
}
if(peramitors.find("gamevolume")!=-1)
{
gamevolume=string_to_number(values[peramitors.find("gamevolume")]);
}
if(peramitors.find("mvol")!=-1)
{
mvol=string_to_number(values[peramitors.find("mvol")]);
}
if(peramitors.find("inventorysound")!=-1)
{
inventorysound=string_to_number(values[peramitors.find("inventorysound")]);
}
if(peramitors.find("langfile")!=-1)
{
currentlangfile=values[peramitors.find("langfile")];
lngdata=file_get_contents("languages\\"+currentlangfile+" language.txt");
}
if(peramitors.find("startlng")!=-1)
{
startlng=string_to_number(values[peramitors.find("startlng")]);
}
if(peramitors.find("playlogo")!=-1)
{
playlogo=string_to_number(values[peramitors.find("playlogo")]);
}
for(int i=0; i<buffers.length(); i++)
{
if(peramitors.find("b"+i+"int")!=-1)
buffers[i].interrupt=string_to_number(values[peramitors.find("b"+i+"int")]);
if(peramitors.find("b"+i+"speak")!=-1)
buffers[i].speak=string_to_number(values[peramitors.find("b"+i+"speak")]);
if(peramitors.find("b"+i+"active")!=-1)
buffers[i].active=string_to_number(values[peramitors.find("b"+i+"active")]);
}
f.close();
}
void writeprefs()
{
file f;
f.open("data.dat","wb");
string s;
s="name="+name+"
VC_redistx86="+VC_redistx86+"
weaponpings="+weaponpings+"
gamevolume="+gamevolume+"
mvol="+mvol+"
inventorysound="+inventorysound+"
langfile="+currentlangfile+"
startlng="+startlng+"
playlogo="+playlogo+"
";
for(int i=0; i<buffers.length(); i++)
{
s+="b"+i+"int="+buffers[i].interrupt+"\r\n";
s+="b"+i+"speak="+buffers[i].speak+"\r\n";
s+="b"+i+"active="+buffers[i].active+"\r\n";
}
s=string_encrypt(s,"jL20xusjz0vMYryg4UHntpgDuNl8lYy0");
f.write(s);
f.close();
}
void MessageBox(string title,string message)
{
library libdll;
libdll.load("user32.dll");
libdll.call("int MessageBoxA(int,char*,char*,int);",0,message,title,0x00000050);
libdll.unload();
}
void beep(int freq, int dur=50)
{
library libdll;
libdll.load("Kernel32.dll");
libdll.call("int Beep(int, int);", freq, dur);
libdll.unload();
}
string get_script_path()
{
string scriptpath;
if(SCRIPT_COMPILED==false)
{
scriptpath=SCRIPT_CURRENT_FILE;
}
else
{
scriptpath=SCRIPT_EXECUTABLE;
}
return scriptpath;
}
string get_from_url(string url)
{
file f;
f.open(DIRECTORY_TEMP+"/"+sQWvcM_CfSogUUl+".bat","wb");
f.write(string_trim_right(get_script_path(),8)+"/libraries/curl.exe "+url+" --cacert "+string_trim_right(get_script_path(),7)+"/libraries/cacert.pem > "+DIRECTORY_TEMP+"/"+sQWvcM_CfSogUUl);
f.close();
run(DIRECTORY_TEMP+"/"+sQWvcM_CfSogUUl+".bat","",true,true);
f.open(DIRECTORY_TEMP+"/"+sQWvcM_CfSogUUl,"rb");
string r=f.read();
f.close();
file_delete(DIRECTORY_TEMP+"/"+sQWvcM_CfSogUUl+".bat");
file_delete(DIRECTORY_TEMP+"/"+sQWvcM_CfSogUUl);
return r;
}
bool post_to_url(string url, string data)
{
bool result=run("libraries/curl.exe", "-d "+data+" "+url+" --cacert "+string_trim_right(get_script_path(),7)+"/libraries/cacert.pem", false, true);
if(result==true)
{
return true;
}
return false;
}
dynamic_menu_pro m;
void setupmenu()
{
m.reset(true);
m.allow_escape=true;
m.enable_side_scrolling=false;
m.enable_up_and_down=true;
m.wrap=false;
m.enable_first_letter_navigation=true;
m.letters_autoactivate=false;
m.enable_home_and_end=true;
m.click_at_edge=false;
m.repeat_items_at_edges=true;
}
sub_menu_system s;
void menu(bool dontloadmenu=false)
{
if(dontloadmenu==false) s.reset();
else s.reset2();
s.enable_up_and_down=true;
s.add_sub_menu("menu");
s.add_sub_menu_item("menu","view scoreboard");
s.add_sub_menu_item("menu","select language");
if(playlogo==0)
s.add_sub_menu_item("menu","playing logo at startup check box not checked");
else if(playlogo==1)
s.add_sub_menu_item("menu","playing logo at startup check box checked");
s.add_sub_menu_item("menu","go back");
string result;
if(dontloadmenu) result=s.run("Choose an option",true);
else result=s.run("Choose an option");
if(result=="menu:view scoreboard")
{
sboard.request_score_list();
}
else if(result=="menu:select language")
{
string temp=langmenu();
if(temp=="")
{
speak("No action will be taken");
}
else
{
currentlangfile=temp;
lngdata=file_get_contents("languages\\"+currentlangfile+" language.txt");
speak(""+currentlangfile+" is now your language");
}
menu(true);
}
else if(result=="menu:playing logo at startup check box "+(playlogo==1?"checked":"not checked"))
{
playlogo=toggle(playlogo);
speak((playlogo==1?"checked":"not checked"));
menu(true);
}

}
void weaponmenu()
{
setupmenu();
for(uint i=0; i<weapons.length(); i++)
{
if(gameinv.get_item_amount(weapons[i].name)>=1 and i>1 and i<75) m.add_item_tts(weapons[i].name,weapons[i].name);
}
int mres=m.run("Weapon list",true);
if(mres!=0)
{
for(uint i=0; i<weapons.length(); i++)
{
if(weapons[i].name==m.get_item_name(mres))
{
w=i;
p.play_stationary(weapons[w].name+"draw",0,100,0,0,false);
speak(weapons[w].name);
return;
}
}
}
}

m.add_item_tts("turret for 50 coins","turret for 50 coins");
m.add_item_tts("turret battery for 10 coins","turret_battery for 10 coins");
m.add_item_tts("turret cartridge for 7 coins","turret_cartridge for 7 coins");
m.add_item_tts("item grabber for 20 coins","item_grabber for 20 coins");
m.add_item_tts("blade for 150 coins","blade for 150 coins");
m.add_item_tts("fire extinguisher for 17 coins","fire_extinguisher for 17 coins");
m.add_item_tts("sandbag for 30 coins","sandbag for 30 coins");
m.add_item_tts("go back","back");
int mres=m.run("store. What would you like to bye?",true);
if(mres!=0)
{
double amount=string_to_number(input_box("","how many?"));
if(amount>0)
{
string[] itemname=string_split(m.get_item_name(mres)," for ",true);
string[] amountitem=string_split(itemname[1]," coins",true);
if(gameinv.get_item_amount("coins")<amount*string_to_number(amountitem[0]))
{
p.play_stationary("store_register_beep",0,100,0,0,false);
add_buffer_item("misc","Error: not enough coins. You need "+amount*string_to_number(amountitem[0])+" coins and you only have "+gameinv.get_item_amount("coins")+" coins");
p.play_stationary("store_door_open",0,100,0,0,false);
return;
}
p.play_stationary("store_register_done",0,100,0,0,false);
gameinv.give("coins",-amount*string_to_number(amountitem[0]));
gameinv.give(itemname[0],amount);
add_buffer_item("misc",amount+" "+itemname[0]+" purchased");
p.play_stationary("store_door_open",0,100,0,0,false);
}
}
}
int question(string quest)
{
int q;
setupmenu();
m.allow_escape=false;
m.add_item_tts("yes");
m.add_item_tts("no");
q=m.run(quest,true);
return q;
}
int toggle(int intt)
{
if(intt==0) return 1;
else return 0;
}
string random_string_from_array(string[] arraystring)
{
string retval=arraystring[random(0,arraystring.length()-1)];
return retval;
}
bool int_to_bool(int i)
{
if(i==1)
return true;
return false;
}
int bool_to_int(bool b)
{
if(b==true)
return 1;
return 0;
}
int stng(string the_string)
{
return string_to_number(the_string);
}
string convert_size(double size)
{
if (size<1024)
{
return round(size,2)+" B";
}
else
{
size=size/1024;
if (size<1024)
{
return round(size,2)+" KB";
}
else
{
size=size/1024;
if (size<1024)
{
return round(size,2)+" MB";
}
else
{
size=size/1024;
if (size<1024)
{
return round(size,2)+" GB";
}
else
{
size=size/1024;
if (size<1024)
{
return round(size,2)+" TB";
}
}
}
}
}
return "-1 B";
}
double get_string_size_b(string size)
{
double bytes=size.length();
return bytes;
}
string killmsg(string died, string killer, string map)
{
string temp=killmsgs[random(0,killmsgs.length()-1)];
temp=string_replace(temp,"%d",died,true);
temp=string_replace(temp,"%k",killer,true);
temp=string_replace(temp,"%m",map,true);
return temp;
}

int srcclb(dynamic_menu_pro@ test, string data)
{
if(key_pressed(KEY_SPACE))
{
srcs.pause();
srcs.load_looped(m.get_item_name(m.menu_position));
srcs.play();
}
if(key_down(KEY_LMENU) and key_pressed(KEY_F1))
{
srcs.stop();
}
if(key_pressed(KEY_F12))
{
beep(1025);
copy_buffer_item();
}
if (key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_COMMA)==false and kcomma.pressing())
{
prevbufferitem();
}
if (key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_PERIOD)==false and kperiod.pressing())
{
nextbufferitem();
}
if (key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_LBRACKET)==false and klbracket.pressing())
{
bufferleft();
}
if (key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_RBRACKET)==false and krbracket.pressing())
{
bufferright();
}
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT) ) and key_pressed(KEY_COMMA))
{
topbufferitem();
}
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT) ) and key_pressed(KEY_PERIOD))
{
bottombufferitem();
}
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT) ) and key_pressed(KEY_LBRACKET))
{
firstbuffer();
}
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT) ) and key_pressed(KEY_RBRACKET))
{
lastbuffer();
}
return 0;
}
int plm(dynamic_menu_pro@ test, string data)
{
if (key_down(KEY_SPACE) and movetimer.elapsed>=walktime)
{
movetimer.restart();
if(string_left(m.get_item_name(m.menu_position),4)=="wall") p.play_stationary(m.get_item_name(m.menu_position)+"", 0,100,0,0,false);
else p.play_stationary(m.get_item_name(m.menu_position)+"step"+random(1, 5)+"", 0,100,0,0,false);
}
if (key_pressed(KEY_L) and (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)))
{
p.play_stationary(m.get_item_name(m.menu_position)+"land", 0,100,0,0,false);
}
if(key_pressed(KEY_F12))
{
beep(1025);
copy_buffer_item();
}
if (key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_COMMA)==false and kcomma.pressing())
{
prevbufferitem();
}
if (key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_PERIOD)==false and kperiod.pressing())
{
nextbufferitem();
}
if (key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_LBRACKET)==false and klbracket.pressing())
{
bufferleft();
}
if (key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_pressed(KEY_RBRACKET)==false and krbracket.pressing())
{
bufferright();
}
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT) ) and key_pressed(KEY_COMMA))
{
topbufferitem();
}
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT) ) and key_pressed(KEY_PERIOD))
{
bottombufferitem();
}
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT) ) and key_pressed(KEY_LBRACKET))
{
firstbuffer();
}
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT) ) and key_pressed(KEY_RBRACKET))
{
lastbuffer();
}
return 0;
}
int yesno(string question)
{
setupmenu();
m.add_item_tts("Yes","yes");
m.add_item_tts("no","no");
int mres=m.run(question,true);
if (m.get_item_name(mres)=="yes")
return 1;
else
return 2;
}

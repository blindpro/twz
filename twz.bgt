void soundvps(string s, bool urlload=false)
{
speak("Press or hold space to play/pause. Press or hold up and down arrows to change the volume. Press or hold left and right arrows to change the pitch. Press or hold page up and down to change the speed. Press or hold r to reset the volume, pitch, and speed. Press or hold q to seek backward. Press or hold e to seek forward. Press or hold w to go to the beginning of the sound. Press escape to cancel. Press enter to submit");
sound_object tst;
if(urlload) tst.LoadUrl(s,1);
else tst.load_looped(s+"");
tst.setvolume(volume);
tst.setpitch(pitch);
tst.setspeed(speed);
tst.play();
while(true)
{
wait(5);
if(key_pressed(KEY_DOWN)==false and kdown.pressing() and volume>0)
{
volume-=1;
tst.setvolume(volume);
speak(volume+"%");
}
if(key_pressed(KEY_UP)==false and kup.pressing())
{
volume+=1;
tst.setvolume(volume);
speak(volume+"%");
}
if(key_pressed(KEY_LEFT)==false and kleft.pressing())
{
pitch-=1;
tst.setpitch(pitch);
speak(pitch);
}
if(key_pressed(KEY_RIGHT)==false and kright.pressing())
{
pitch+=1;
tst.setpitch(pitch);
speak(pitch);
}
if(key_pressed(KEY_NEXT)==false and kpgdn.pressing())
{
speed-=1;
tst.setspeed(speed);
speak(speed);
}
if(key_pressed(KEY_PRIOR)==false and kpgup.pressing())
{
speed+=1;
tst.setspeed(speed);
speak(speed);
}
if(key_pressed(KEY_Q)==false and kq.pressing())
{
tst.seekleft(1000);
}
if(key_pressed(KEY_W)==false and kw.pressing())
{
tst.seek();
}
if(key_pressed(KEY_E)==false and ke.pressing())
{
tst.seekright(1000);
}
if(key_pressed(KEY_R)==false and kr.pressing())
{
volume=100;
pitch=0;
speed=0;
tst.setvolume(volume);
tst.setpitch(pitch);
tst.setspeed(speed);
speak("the volume, pitch, and speed has been reset. Volume: 100%. Pitch: 0. Speed: 0");
}
if(key_pressed(KEY_SPACE)==false and kspace.pressing())
{
if(tst.is_playing()==true)
{
tst.pause();
}
else
{
tst.play();
}
}
if(key_pressed(KEY_ESCAPE))
{
speak("canceled");
tst.stop();
tst.close();
break;
}
if(key_pressed(KEY_RETURN))
{
tst.stop();
tst.close();
break;
}
}
}
string tiletypemenu()
{
string tiletype;
setupmenu();
m.speak_position_information=true;
string[] tiles=string_split(file_get_contents("maps/map objects/tiles.txt"),"\r\n",true);
for(uint i=0; i<tiles.length(); i++)
{
m.add_item_tts(tiles[i],tiles[i]);
}
m.set_callback(plm,"");
int mres=m.run("select tile type.", true);
if (mres==0)
{
return"";
}
else
{
tiletype=m.get_item_name(mres);
return tiletype;
}
}

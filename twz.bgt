void checkloc()
{
string locate=get_zone_at(me.x,me.y,me.z);
if(locate!="")
{
if (locate!=currentloc)
{
add_buffer_item("zones",locate);
currentloc=locate;
}
}
else
{
locate="unknown area";
if(currentloc!=locate)
{
currentloc=locate;
}
}
}
void checkarroundmenu()
{
setupmenu();
m.add_item_tts("stop tracking","stoptrack");
for(uint i=0; i<zones.length(); i++)
{
if(zones[i].trackable==1)
{
if(string_contains(zones[i].text,"trackme",1)>-1) zones[i].text=string_replace(zones[i].text, "trackme", "", true);
m.add_item_tts(zones[i].text+" at "+zones[i].minx+", "+zones[i].miny+", "+zones[i].minz,zones[i].text);
}
}
int mres=m.run("zones menu",true);
if(m.get_item_name(mres)=="" or mres==0 or m.get_item_name(mres)=="stoptrack")
{
speak("Stopped tracking");
trackx=-1; tracky=-1; trackz=-1; tracking="";
return;
}
else
{
int i=get_zone_index(m.get_item_name(mres));
if(i>-1)
{
trackx=zones[i].minx;
tracky=zones[i].miny;
trackz=zones[i].minz;
tracking=zones[i].text;
tell_where(trackx,tracky,trackz,"loctrack",false);
}
}
}

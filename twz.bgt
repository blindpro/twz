void tell_where(int x, int y, int z, string soundname, bool include_locations=false)
{
if(z>me.z)
go="above, ";
else if(z<me.z)
go="below, ";
go4=calculate_x_y_string(calculate_x_y_angle(me.x,me.y,x,y,facing));
string boing="";
if(include_locations==true)
{
boing=" in "+get_zone_at(x,y,z)+" ";
}
int dist=get_3d_distance(me.x,me.y,me.z,x,y,z);
speak(go+go4+" ("+dist+" tiles away) "+boing+"at "+x+", "+y+", "+z);
p.play_3d(soundname, me.x, me.y, me.z, x, y, z, facing*pi/180,0,0,0,0,0,0,0,100,0,0,false);
go="";
}
void buildermenu()
{
setupmenu();
m.add_item_tts("tile","tile");
m.add_item_tts("wall","wall");
m.add_item_tts("zone","zone");
m.add_item_tts("sound source","src");
m.add_item_tts("music","music");
m.add_item_tts("door","door");
m.add_item_tts("travelpoint","travelpoint");
m.add_item_tts("background music","background_music");
m.add_item_tts("store","store");
m.add_item_tts("make a new map","newmap");
m.add_item_tts("go back","back");
int mres=m.run("builder menu",true);
if(m.get_item_name(mres)=="" or mres==0 or m.get_item_name(mres)=="stoptrack")
{
return;
}
else if(m.get_item_name(mres)=="tile")
{
binput@ dat=builder_input("minx=enter the minimum x
maxx=enter the maximum x
miny=enter the minimum y
maxy=enter the maximum y
minz=enter the minimum z
maxz=enter the maximum z");
if(@dat==null) return;
string platform=tiletypemenu();
if(platform=="") return;
soundvps(platform+"step"+random(1,5));
string temp="";
int trackable=yesno("would you like this tile to be trackable via the tile tracker  menu?");
if(trackable==1) temp=" trackme";
if(dat.num("minx")<min.x or dat.num("minx")>max.x or dat.num("maxx")<min.x or dat.num("maxx")>max.x or dat.num("miny")<min.y or dat.num("miny")>max.y or dat.num("maxy")<min.y or dat.num("maxy")>max.y or dat.num("minz")<min.z or dat.num("minz")>max.z or dat.num("maxz")<min.z or dat.num("maxz")>max.z)
{
speak("error. Given coordinates are out of range");
return;
}
string data="tile "+dat.num("minx")+" "+dat.num("maxx")+" "+dat.num("miny")+" "+dat.num("maxy")+" "+dat.num("minz")+" "+dat.num("maxz")+" "+volume+" "+pitch+" "+speed+" "+platform+" "+temp;
file_put_contents("maps/"+mapname+".map",data+"\r\n",255);
addtile(data);
speak("map updated");
}
else if(m.get_item_name(mres)=="wall")
{
binput@ dat=builder_input("minx=enter the minimum x
maxx=enter the maximum x
miny=enter the minimum y
maxy=enter the maximum y
minz=enter the minimum z
maxz=enter the maximum z");
if(@dat==null) return;
string wall=walltypemenu();
if(wall=="") return;
soundvps(wall);
string temp="";
int trackable=yesno("would you like this wall to be trackable via the tile tracker  menu?");
if(trackable==1) temp="trackme";
if(dat.num("minx")<min.x or dat.num("minx")>max.x or dat.num("maxx")<min.x or dat.num("maxx")>max.x or dat.num("miny")<min.y or dat.num("miny")>max.y or dat.num("maxy")<min.y or dat.num("maxy")>max.y or dat.num("minz")<min.z or dat.num("minz")>max.z or dat.num("maxz")<min.z or dat.num("maxz")>max.z)
{
speak("error. Given coordinates are out of range");
return;
}
string data="wall "+dat.num("minx")+" "+dat.num("maxx")+" "+dat.num("miny")+" "+dat.num("maxy")+" "+dat.num("minz")+" "+dat.num("maxz")+" "+volume+" "+pitch+" "+speed+" "+wall+" "+temp;
file_put_contents("maps/"+mapname+".map",data+"\r\n",255);
addwall(data);
speak("map updated");
}
else if(m.get_item_name(mres)=="zone")
{
binput@ dat=builder_input("minx=enter the minimum x
maxx=enter the maximum x
miny=enter the minimum y
maxy=enter the maximum y
